[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
[user]
	signingkey = ssh-rsa 
	name = Dida Hsu
	email = dida.frontend@gmail.com
[init]
	defaultBranch = main
[pull]
	rebase = true
[core]
	editor = nvim
	pager = delta
[rerere]
	enabled = true
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
[diff]
	tool = difftastic

[difftool "difftastic"]
	cmd = difft "$LOCAL" "$REMOTE"

[difftool]
	prompt = false

# 或者用 alias
[alias]
	dft = difftool
	dlog = "!f() { GIT_EXTERNAL_DIFF=difft git log -p --ext-diff $@; }; f"
								



